{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Paseo Usage Bridge",
  "version": "0.2.11",
  "identifier": "com.yajinni.paseousagebridge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Paseo Usage Bridge",
        "label": "main",
        "width": 1440,
        "height": 850,
        "minWidth": 960,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "category": "Utility",
    "shortDescription": "Monitor AI subscription usage across multiple providers",
    "longDescription": "A standalone Windows and macOS desktop app for monitoring OpenAI Codex, Anthropic Claude, Google Antigravity, and OpenCode Go subscription usage and exposing sanitized quota data to Paseo over localhost."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM0RjhBNTZBRjU5MjNFRUUKUldUdVBwTDFhcVg0eE0vZ2NtaDBRYXk4RUJRcThBRi9FL1E4NmFXYkJDWE1XMFVzcHFzMzNsWlkK",
      "endpoints": [
        "https://github.com/yajinni/Paseo-Usage-Bridge/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
